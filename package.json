{
  "pnpm": {
    "overrides": {
      "lexical": "0.14.5",
      "@lexical/selection": "0.14.5",
      "@lexical/utils": "0.14.5",
      "@lexical/rich-text": "0.14.5",
      "@lexical/plain-text": "0.14.5",
      "@lexical/history": "0.14.5"
    }
  },
  "name": "notedit",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "private": true,
  "scripts": {
    "dev:client": "pnpm --filter client dev",
    "dev:server": "pnpm --filter server dev",
    "dev": "concurrently -n \"WEB,API\" -c \"cyan,green\" \"pnpm run dev:client\" \"pnpm run dev:server\"",
    "test": "echo \"Error: no test specified\" && exit 1",
    "prepare": "husky",
    "build": "pnpm -r run build"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.28.2",
  "devDependencies": {
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "concurrently": "^9.2.1",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.4"
  },
  "lint-staged": {
    "web/client/**/*.{ts,tsx}": [
      "pnpm --filter client exec eslint --max-warnings=0 --no-warn-ignored"
    ]
  }
}
